// 自定义样式：全站背景图（全透方案）
// 配合 _config.next.yml 的 custom_file_path.style 注入
// 设计目标：背景图大面积可见，内容区透明，用文字阴影保证可读性

// === 背景图铺底 ===
body {
  background-image: url('/zzh-notes/images/background.webp');
  background-size: cover;
  background-position: center center;
  background-repeat: no-repeat;
  background-attachment: fixed;
}

// === 内容区全部透明，让背景图透出 ===
// 清掉我之前加的遮罩底，也清掉 NexT 自带的不透明卡片底
.header,
.main,
.sidebar,
.footer,
.header-inner,
.main-inner,
.sidebar-inner,
.post-block,
.posts-list {
  background: transparent !important;
}

// 去掉内容区的 box-shadow（透明卡片上的阴影会很脏）
.main,
.sidebar {
  box-shadow: none !important;
}

// === 文字可读性兜底 ===
// 背景图透出后，正文直接压在照片上。用半透明文字阴影保证任何底色上都读得清。
// 阴影用接近底色的浅色，避免黑边看起来脏。
body {
  color: #1a1a1a;
  text-shadow: 0 1px 2px rgba(255, 255, 255, 0.85),
               0 0 8px rgba(255, 255, 255, 0.6);
}

// 标题、链接加强一档
h1, h2, h3, h4, h5, h6 {
  text-shadow: 0 1px 3px rgba(255, 255, 255, 0.9),
               0 0 10px rgba(255, 255, 255, 0.7);
}

a {
  text-shadow: 0 1px 2px rgba(255, 255, 255, 0.85);
}

// === 暗黑模式适配 ===
@media (prefers-color-scheme: dark) {
  body {
    color: #f0f0f0;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.95),
                 0 0 8px rgba(0, 0, 0, 0.8);
  }

  h1, h2, h3, h4, h5, h6 {
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.95),
                 0 0 12px rgba(0, 0, 0, 0.85);
  }

  a {
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.95);
  }
}
