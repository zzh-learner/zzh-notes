// 自定义样式：低调现代版
// 配合 _config.next.yml 的 custom_file_path.style 注入
// 设计目标：背景图压到若隐若现，内容区回到干净白/暗底，文字当主角

// === 恒定暗色：data-theme 永久为 dark（head.njk FOUC 写死） ===
// NexT 原生 _colors.styl 走 @media (prefers-color-scheme: dark)，我们用
// [data-theme="dark"] 覆盖（特异性高于媒体查询），钉死暗色变量。
[data-theme="dark"] {
  --body-bg-color: #0f0f11;
  --content-bg-color: #18181b;
  --card-bg-color: #27272a;
  --text-color: #f4f4f5;
  --selection-bg: #22d3ee;
  --selection-color: #09090b;
  --blockquote-color: #a1a1aa;
  --link-color: #f4f4f5;
  --link-hover-color: #22d3ee;
  --brand-color: #f4f4f5;
  --brand-hover-color: #f4f4f5;
  --table-row-odd-bg-color: #18181b;
  --table-row-hover-bg-color: #27272a;
  --menu-item-bg-color: #27272a;
  --theme-color: #22d3ee;
  --border-color: #27272a;
  color-scheme: dark;
}

// 图片透明度随主题（对齐 NexT 默认行为：暗色下 img opacity .75）
[data-theme="dark"] img { opacity: 0.75; }
[data-theme="dark"] img:hover { opacity: 0.9; }

// === 背景：Three.js 星空 canvas（暗色）/ 纯色兜底（亮色或 JS 失败） ===
// body 底色是兜底：canvas 未注入或降级时，暗色显 #0f0f11 黑底。
// 三层结构：body 兜底底色 → #starfield canvas（z-index:-2）→ 内容区（z-index≥0）
body {
  background-color: var(--body-bg-color, #0f0f11);
  position: relative;
  min-height: 100vh;
}

// 星空 canvas：JS 动态创建（body-end.njk Task 3），失败则无此元素。
// opacity 绑 --bg-overlay-opacity（滑块 IIFE 写入 <html>）。
// 现有 IIFE 语义：overlayOpacity = 1 - sliderVal/100，值越大遮罩越透（照片越清晰）。
// 对 canvas 再反一次（1 - var）还原成"值越大星空越清晰"：
//   滑块 100 → --bg-overlay-opacity=0 → canvas opacity=1（全亮）
//   滑块 0   → --bg-overlay-opacity=1 → canvas opacity=0（隐藏）
#starfield {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -2;
  pointer-events: none;
  opacity: calc(1 - var(--bg-overlay-opacity, 0.5));
  transition: opacity 0.4s ease, visibility 0.4s ease;
}

// === 内容区不透明白/暗底（覆盖 Task 2 之外的细节） ===
// NexT 默认就是白底，这里只做微调
.main-inner {
  background: transparent;  // Gemini scheme 透明，让 $content-bg-color 在 .post-block 上生效
}

// === 桌面宽屏下限制总宽度并居中 ===
// 原因：Gemini scheme 的 body > main.main 直接挂在 body 下没有中间容器，
// .main-inner width: calc(100% - 252px) 跟随 .main 宽度，1920px+ 视口下
// 内容区会撑到 1100px+，阅读行宽过长（理想 60-90 字符 ≈ 700-900px）。
// 这里把 .main 限制到 1200px 居中，sidebar 和内容区一起往中间收。
@media (min-width: 1200px) {
  .main {
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
  }
}

// === 暗色模式 body 底色（canvas 降级时的兜底黑） ===
[data-theme="dark"] body {
  background-color: #0f0f11;
}

// === 阅读进度条（GSAP 控制 width，这里只定样式） ===
.reading-progress-bar {
  position: fixed;
  top: 0;
  left: 0;
  height: 2px;
  width: 0;
  background: var(--theme-color);
  z-index: 1000;
  transition: width 0.1s linear;
}

// === 动效元素初始态（仅 gsap-ready 时启用，防 JS 失败内容不可见） ===
// 见 Task 7 的工程兜底说明
html.gsap-ready .fade-up {
  opacity: 0;
  transform: translateY(24px);
}

// === 文章卡片改透明（配合背景明暗滑块） ===
// 决策依据：用户在 brainstorming §3 明确选"文章区也透明，文字直接叠在背景图上"。
// 滑块拉到最右时，背景图完全可见，正文直接压在图上。
// 风险：某些复杂背景图会让正文难辨（用户已接受，见 spec §9）。
.posts-expand .post-block,
.post-block {
  background: transparent;
}

// 首页文章卡片 hover 边框变深青
.posts-expand .post-block {
  transition: border-color 0.2s ease, transform 0.2s ease;
  border: 1px solid var(--border-color, #e4e4e7);
  border-radius: 8px;
}
.posts-expand .post-block:hover {
  border-color: var(--theme-color);
}

// 标题宋体已通过 _config.next.yml 的 font 段应用，这里不重复

// === prefers-reduced-motion 跳过所有动效 ===
@media (prefers-reduced-motion: reduce) {
  html.gsap-ready .fade-up {
    opacity: 1 !important;
    transform: none !important;
  }
  .reading-progress-bar {
    display: none;
  }
  * {
    animation: none !important;
    transition: none !important;
  }
}

// === 自定义 header（覆盖 NexT 默认 header 视觉） ===
// 重要：NexT Gemini 的 <header class="header"> 不是页面顶部 banner，而是
// 位于左侧 sidebar 列内（.column，桌面端 ~240px 宽）。next_inject('header')
// 是在该 sidebar 列内部注入，所以 .custom-header 被塞进了一个窄列里，
// 在桌面宽屏下会被压缩到 240px。
// 解决：用 position: fixed 突破 sidebar 列约束，浮到视口顶部全宽显示。
.custom-header {
  position: fixed !important;
  top: 0;
  left: 0;
  right: 0;
  width: 100%;
  z-index: 100;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border-bottom: 1px solid var(--border-color, #e4e4e7);
  transition: height 0.25s ease, padding 0.25s ease;
}

// 给 fixed header 让位，避免内容被遮（header 高度约 70-80px，padding 24px）
// 用 body padding-top 而不是 margin，避免背景图偏移
body {
  padding-top: 72px;
}
@media (max-width: 767px) {
  body { padding-top: 100px; }  // 移动端 header 纵向堆叠，更高
}

.custom-header-inner {
  max-width: 900px;
  margin: 0 auto;
  padding: 24px 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: padding 0.25s ease;
}

// 滚动收缩状态（GSAP 加 .scrolled 类，见 Task 7）
.custom-header.scrolled .custom-header-inner {
  padding: 14px 40px;
}

.custom-header-brand {
  font-family: 'Playfair Display', 'Noto Serif SC', serif;
  font-weight: 600;
  font-size: 1.125em;
  color: var(--text-color, #09090b);
  text-decoration: none;
}

.custom-header-nav {
  display: flex;
  gap: 24px;
  font-family: 'Public Sans', 'Noto Sans SC', sans-serif;
  font-size: 0.875em;
}

.custom-header-nav a {
  color: var(--text-color, #09090b);
  text-decoration: none;
  transition: color 0.2s ease;
}

.custom-header-nav a:hover {
  color: var(--theme-color);
}

// 暗色模式 header（用 [data-theme] 替代 prefers-color-scheme）
[data-theme="dark"] .custom-header {
  background: rgba(24, 24, 27, 0.8);
  border-bottom-color: #27272a;
}
[data-theme="dark"] .custom-header-brand,
[data-theme="dark"] .custom-header-nav a {
  color: #f4f4f5;
}

@media (max-width: 767px) {
  .custom-header-inner {
    flex-direction: column;
    gap: 8px;
    padding: 16px 20px;
  }
  .custom-header-nav {
    gap: 16px;
  }
}

// === 图片 lazyload fade 初始态（仅 gsap-ready） ===
html.gsap-ready .post-body img {
  opacity: 0;
  transition: opacity 0.3s ease;
}
@media (prefers-reduced-motion: reduce) {
  html.gsap-ready .post-body img { opacity: 1 !important; }
}

// === 合并默认 header 与自定义 header（Important I1 修复） ===
// 背景：custom_file_path.header 是 append 而非 replace，默认 NexT header（含
// site-brand-container / site-meta 居中标题 / site-nav）和 .custom-header 同时
// 渲染并叠在一起。这里把默认 .header 的视觉外壳压扁隐藏，只保留功能性子元素：
//   - .site-nav-toggle .toggle     移动端侧栏开关（next-boot.js 绑定 click）
//   - .site-nav-right  .toggle     搜索按钮（.popup-trigger，local-search.js 绑定）
//   - .search-pop-overlay          搜索弹层（自身 visibility:hidden，激活时可见）
// 注意：不能用 display:none 整体隐藏 .header，否则上述功能 DOM 也会消失。

// 1) 让默认 header 不占布局、背景透明、去掉 Gemini 的卡片样式
header.header {
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
  // 高度坍缩：site-meta 被隐藏后，容器不再撑高
  height: auto;
  min-height: 0;
  padding: 0;
  position: relative;
  z-index: 90;  // 低于 .custom-header(100)，让自定义 header 视觉在上
}

// 2) 隐藏 site-brand-container 的视觉（卡片背景 + flex 占位），但保留其内部
//    的两个 .toggle（功能 DOM）。用 position:absolute 把它们从布局里拎出来。
.header .site-brand-container {
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
  padding: 0;
  position: static;   // 让 .toggle 的 position:fixed 以视口为参考
}

// 3) 隐藏默认 header 的 brand 文本与 logo 装饰（自定义 header 已有 brand）
.header .site-meta,
.header .site-meta .brand,
.header .site-meta .site-title,
.header .site-meta .site-subtitle,
.header .site-meta .logo-line,
.header .site-meta .custom-logo-image {
  display: none !important;
}

// 4) 功能按钮处理：
//    - .site-nav-toggle .toggle（移动端汉堡）：保留 fixed 浮动，仅移动端可见
//    - .site-nav-right  .toggle（搜索）：已搬进 .custom-header-nav 内（紧挨主题
//      切换按钮），原位置直接 display:none 隐藏。
//    之前搜索按钮用 position:fixed 浮在视口右上角，和主题切换按钮位置接近，
//    会重叠按错。现在两个工具按钮都在 .custom-header-nav 的 flex 流里，
//    有 24px gap 间隔，物理上不可能重叠。
.header .site-nav-toggle {
  display: block;   // 覆盖 NexT 默认 display:none
}
.header .site-nav-right {
  display: none !important;   // 搜索按钮已搬进自定义 header，原位置隐藏
}

// 桌面端（>= 768px）：隐藏汉堡（自定义 header 提供导航）
@media (min-width: 768px) {
  .header .site-nav-toggle {
    display: none !important;
  }
}

// 移动端（<= 767px）：汉堡 fixed 到视口左上角
@media (max-width: 767px) {
  .header .site-nav-toggle .toggle {
    position: fixed;
    top: 18px;        // 与 .custom-header-inner 移动端 padding(16px) 大致对齐
    left: 20px;
    z-index: 110;     // 高于 .custom-header(100)
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--text-color, #09090b);
    padding: 8px;
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  // 汉堡线条颜色随文本色
  .header .site-nav-toggle .toggle .toggle-line {
    background: var(--text-color, #09090b);
  }
  // 搜索弹层在移动端满屏（NexT 原生已有，这里仅确保 z-index 高于 header）
  .search-pop-overlay {
    z-index: 200;
  }
}

// 暗色模式下汉堡颜色对齐自定义 header 暗色文本
// 用 [data-theme] 替代 prefers-color-scheme
[data-theme="dark"] .header .site-nav-toggle .toggle {
  color: #f4f4f5;
}
[data-theme="dark"] .header .site-nav-toggle .toggle .toggle-line {
  background: #f4f4f5;
}

// 5) 防御性兜底：NexT motion 开启时会把 .site-brand-container .toggle 设为
//    opacity:0 等 GSAP 动画填充。如果 GSAP 加载失败/被 reduce-motion 关闭，
//    汉堡按钮会永远不可见不可点。这里强制可见，保证功能不依赖 JS。
.use-motion .header .site-brand-container .toggle {
  opacity: 1 !important;
}
@media (prefers-reduced-motion: reduce) {
  .header .site-nav-toggle .toggle {
    opacity: 1 !important;
  }
}

// === 自定义 header 里的搜索按钮（从默认 header 搬来） ===
// 复用按钮骨架样式（32px 方形、transparent 底、hover 高亮），与 .custom-header-bg 视觉一致
.custom-header-search {
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 4px 8px;
  margin-left: 8px;
  width: 32px;
  height: 32px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: var(--text-color, #09090b);
  border-radius: 6px;
  transition: background 0.2s ease, color 0.2s ease;
  vertical-align: middle;
}
.custom-header-search:hover {
  background: rgba(0, 0, 0, 0.05);
  color: var(--theme-color);
}
[data-theme="dark"] .custom-header-search {
  color: #f4f4f5;
}
[data-theme="dark"] .custom-header-search:hover {
  background: rgba(255, 255, 255, 0.08);
  color: #22d3ee;
}
@media (prefers-reduced-motion: reduce) {
  .custom-header-search { transition: none; }
}

// === 背景明暗调节按钮（复用 .custom-header-search 的按钮骨架） ===
.custom-header-bg {
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 4px 8px;
  margin-left: 8px;
  width: 32px;
  height: 32px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: var(--text-color, #09090b);
  border-radius: 6px;
  transition: background 0.2s ease, color 0.2s ease;
  vertical-align: middle;
}
.custom-header-bg:hover {
  background: rgba(0, 0, 0, 0.05);
  color: var(--theme-color);
}
// popover 打开时按钮高亮，给"正在操作"反馈
.custom-header-bg[aria-expanded="true"] {
  background: rgba(8, 145, 178, 0.1);
  color: var(--theme-color);
}
[data-theme="dark"] .custom-header-bg { color: #f4f4f5; }
[data-theme="dark"] .custom-header-bg:hover {
  background: rgba(255, 255, 255, 0.08);
  color: #22d3ee;
}
@media (prefers-reduced-motion: reduce) {
  .custom-header-bg { transition: none; }
}

// === 背景明暗 popover ===
// popover 在 <body> 根级（header.njk 中 </header> 之后），不在 .custom-header 内。
// 这样它处于根 stacking context，z-index:110 直接与 .custom-header 的 z-index:100
// 在同一上下文比较，110 > 100 正确把 popover 叠在 header 上方。
// 若仍在 .custom-header 内，backdrop-filter 会为 fixed 后代建包含块，且 110 无法
// 超出 header 自身 stacking context（100），会被 header 遮挡/锚定错位。
.bg-popover {
  position: fixed;
  top: 72px;              // 桌面端 header 高度（body padding-top: 72px）
  right: 24px;
  z-index: 110;           // popover 在 body 根级，z-index 110 > header 100（同根 stacking context）
  min-width: 220px;
  padding: 16px 20px;
  background: var(--content-bg-color, #ffffff);
  border: 1px solid var(--border-color, #e4e4e7);
  border-radius: 8px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  font-family: 'Public Sans', 'Noto Sans SC', sans-serif;
  font-size: 0.875em;
}
[data-theme="dark"] .bg-popover {
  background: var(--content-bg-color, #18181b);
  border-color: #27272a;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
}
// hidden 属性兜底（防被其他 display 规则覆盖）
.bg-popover[hidden] { display: none; }

.bg-popover-label {
  display: block;
  margin-bottom: 12px;
  font-weight: 500;
  color: var(--text-color, #09090b);
}
.bg-popover-row {
  display: flex;
  align-items: center;
  gap: 12px;
}
.bg-popover-min, .bg-popover-max {
  flex-shrink: 0;
  color: var(--blockquote-color, #52525b);
  font-size: 0.85em;
}

// === 滑块（跨浏览器统一外观） ===
.bg-slider {
  flex: 1;
  -webkit-appearance: none;
  appearance: none;
  height: 4px;
  background: var(--border-color, #e4e4e7);
  border-radius: 2px;
  outline: none;
  cursor: pointer;
}
.bg-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: var(--theme-color);
  border: 2px solid var(--content-bg-color, #ffffff);
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
}
.bg-slider::-moz-range-thumb {
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: var(--theme-color);
  border: 2px solid var(--content-bg-color, #ffffff);
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
}
.bg-slider:focus-visible {
  // 聚焦时轨道淡光晕，辅助键盘定位
  box-shadow: 0 0 0 4px rgba(8, 145, 178, 0.2);
}

// === 移动端 popover 满宽 ===
@media (max-width: 767px) {
  .bg-popover {
    top: 100px;            // 移动端 header 纵向堆叠更高（body padding-top: 100px）
    right: 12px;
    left: 12px;
    min-width: 0;
  }
}
