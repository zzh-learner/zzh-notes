// 自定义样式：低调现代版
// 配合 _config.next.yml 的 custom_file_path.style 注入
// 设计目标：背景图压到若隐若现，内容区回到干净白/暗底，文字当主角

// === 主题切换：[data-theme] 控制所有暗色变量 ===
// head.njk 的 FOUC 脚本会在 CSS 应用前同步设好 data-theme 属性
// NexT 原生 _colors.styl 走 @media (prefers-color-scheme: dark)，我们用
// [data-theme="dark"] 覆盖，让手动按钮生效（优先级高于媒体查询）。
// 暗色变量值和 _variables/base.styl 的 *-dark 一致。
[data-theme="dark"] {
  --body-bg-color: #0f0f11;
  --content-bg-color: #18181b;
  --card-bg-color: #27272a;
  --text-color: #f4f4f5;
  --selection-bg: #22d3ee;
  --selection-color: #09090b;
  --blockquote-color: #a1a1aa;
  --link-color: #f4f4f5;
  --link-hover-color: #22d3ee;
  --brand-color: #f4f4f5;
  --brand-hover-color: #f4f4f5;
  --table-row-odd-bg-color: #18181b;
  --table-row-hover-bg-color: #27272a;
  --menu-item-bg-color: #27272a;
  --theme-color: #22d3ee;
  --border-color: #27272a;
  color-scheme: dark;
}

// === 强制亮色（解决"系统暗色 + 用户切亮色"冲突） ===
// 没有这个块的话：用户系统是暗色、却手动切到亮色时，NexT 的
// @media (prefers-color-scheme: dark) 仍会激活，把变量又改回暗色。
// 这个 [data-theme="light"] 块强制覆盖回亮色值。
[data-theme="light"] {
  --body-bg-color: #fafafa;
  --content-bg-color: #ffffff;
  --card-bg-color: #f5f5f5;
  --text-color: #09090b;
  --selection-bg: #0891b2;
  --selection-color: #ffffff;
  --blockquote-color: #52525b;
  --link-color: #09090b;
  --link-hover-color: #0891b2;
  --brand-color: #ffffff;
  --brand-hover-color: #ffffff;
  --table-row-odd-bg-color: #f9f9f9;
  --table-row-hover-bg-color: #f5f5f5;
  --menu-item-bg-color: #f5f5f5;
  --theme-color: #0891b2;
  --border-color: #e4e4e7;
  color-scheme: light;
}
// 图片透明度随主题（对齐 NexT 默认行为：暗色下 img opacity .75）
[data-theme="dark"] img { opacity: 0.75; }
[data-theme="dark"] img:hover { opacity: 0.9; }
[data-theme="light"] img { opacity: 1; }

// === 背景图 + 强遮罩（亮色 92%） ===
body {
  background-image: url('/zzh-notes/images/background.webp');
  background-size: cover;
  background-position: center center;
  background-repeat: no-repeat;
  background-attachment: fixed;
  position: relative;
  min-height: 100vh;
}

// 用 ::before 做半透明遮罩，让背景图变成肌理
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background: rgba(250, 250, 250, 0.92);
  z-index: -1;
  pointer-events: none;
}

// === 内容区不透明白/暗底（覆盖 Task 2 之外的细节） ===
// NexT 默认就是白底，这里只做微调
.main-inner {
  background: transparent;  // Gemini scheme 透明，让 $content-bg-color 在 .post-block 上生效
}

// === 暗色模式遮罩（深 88%） ===
// 用 [data-theme="dark"] 替代原 prefers-color-scheme，让手动按钮生效
[data-theme="dark"] body::before {
  background: rgba(15, 15, 17, 0.88);
}

// === 阅读进度条（GSAP 控制 width，这里只定样式） ===
.reading-progress-bar {
  position: fixed;
  top: 0;
  left: 0;
  height: 2px;
  width: 0;
  background: var(--theme-color);
  z-index: 1000;
  transition: width 0.1s linear;
}

// === 动效元素初始态（仅 gsap-ready 时启用，防 JS 失败内容不可见） ===
// 见 Task 7 的工程兜底说明
html.gsap-ready .fade-up {
  opacity: 0;
  transform: translateY(24px);
}

// 首页文章卡片 hover 边框变深青
.posts-expand .post-block {
  transition: border-color 0.2s ease, transform 0.2s ease;
  border: 1px solid var(--border-color, #e4e4e7);
  border-radius: 8px;
}
.posts-expand .post-block:hover {
  border-color: var(--theme-color);
}

// 标题宋体已通过 _config.next.yml 的 font 段应用，这里不重复

// === prefers-reduced-motion 跳过所有动效 ===
@media (prefers-reduced-motion: reduce) {
  html.gsap-ready .fade-up {
    opacity: 1 !important;
    transform: none !important;
  }
  .reading-progress-bar {
    display: none;
  }
  * {
    animation: none !important;
    transition: none !important;
  }
}

// === 自定义 header（覆盖 NexT 默认 header 视觉） ===
.custom-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border-bottom: 1px solid var(--border-color, #e4e4e7);
  transition: height 0.25s ease, padding 0.25s ease;
}

.custom-header-inner {
  max-width: 900px;
  margin: 0 auto;
  padding: 24px 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: padding 0.25s ease;
}

// 滚动收缩状态（GSAP 加 .scrolled 类，见 Task 7）
.custom-header.scrolled .custom-header-inner {
  padding: 14px 40px;
}

.custom-header-brand {
  font-family: 'Playfair Display', 'Noto Serif SC', serif;
  font-weight: 600;
  font-size: 1.125em;
  color: var(--text-color, #09090b);
  text-decoration: none;
}

.custom-header-nav {
  display: flex;
  gap: 24px;
  font-family: 'Public Sans', 'Noto Sans SC', sans-serif;
  font-size: 0.875em;
}

.custom-header-nav a {
  color: var(--text-color, #09090b);
  text-decoration: none;
  transition: color 0.2s ease;
}

.custom-header-nav a:hover {
  color: var(--theme-color);
}

// 暗色模式 header（用 [data-theme] 替代 prefers-color-scheme）
[data-theme="dark"] .custom-header {
  background: rgba(24, 24, 27, 0.8);
  border-bottom-color: #27272a;
}
[data-theme="dark"] .custom-header-brand,
[data-theme="dark"] .custom-header-nav a {
  color: #f4f4f5;
}

// === 主题切换按钮 ===
.theme-toggle {
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 4px 8px;
  margin-left: 8px;
  width: 32px;
  height: 32px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: var(--text-color, #09090b);
  border-radius: 6px;
  transition: background 0.2s ease, color 0.2s ease;
  vertical-align: middle;
}
.theme-toggle:hover {
  background: rgba(0, 0, 0, 0.05);
  color: var(--theme-color);
}
[data-theme="dark"] .theme-toggle {
  color: #f4f4f5;
}
[data-theme="dark"] .theme-toggle:hover {
  background: rgba(255, 255, 255, 0.08);
  color: #22d3ee;
}
// 图标显隐：亮色显示月亮（点击切到暗色），暗色显示太阳（切回亮色）
.theme-toggle-icon {
  font-size: 0.875em;
  line-height: 1;
}
.theme-toggle-moon { display: inline; }
.theme-toggle-sun  { display: none; }
[data-theme="dark"] .theme-toggle-moon { display: none; }
[data-theme="dark"] .theme-toggle-sun  { display: inline; }
// reduced-motion 下也要保证按钮可点（不动效）
@media (prefers-reduced-motion: reduce) {
  .theme-toggle { transition: none; }
}

@media (max-width: 767px) {
  .custom-header-inner {
    flex-direction: column;
    gap: 8px;
    padding: 16px 20px;
  }
  .custom-header-nav {
    gap: 16px;
  }
}

// === 图片 lazyload fade 初始态（仅 gsap-ready） ===
html.gsap-ready .post-body img {
  opacity: 0;
  transition: opacity 0.3s ease;
}
@media (prefers-reduced-motion: reduce) {
  html.gsap-ready .post-body img { opacity: 1 !important; }
}

// === 合并默认 header 与自定义 header（Important I1 修复） ===
// 背景：custom_file_path.header 是 append 而非 replace，默认 NexT header（含
// site-brand-container / site-meta 居中标题 / site-nav）和 .custom-header 同时
// 渲染并叠在一起。这里把默认 .header 的视觉外壳压扁隐藏，只保留功能性子元素：
//   - .site-nav-toggle .toggle     移动端侧栏开关（next-boot.js 绑定 click）
//   - .site-nav-right  .toggle     搜索按钮（.popup-trigger，local-search.js 绑定）
//   - .search-pop-overlay          搜索弹层（自身 visibility:hidden，激活时可见）
// 注意：不能用 display:none 整体隐藏 .header，否则上述功能 DOM 也会消失。

// 1) 让默认 header 不占布局、背景透明、去掉 Gemini 的卡片样式
header.header {
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
  // 高度坍缩：site-meta 被隐藏后，容器不再撑高
  height: auto;
  min-height: 0;
  padding: 0;
  position: relative;
  z-index: 90;  // 低于 .custom-header(100)，让自定义 header 视觉在上
}

// 2) 隐藏 site-brand-container 的视觉（卡片背景 + flex 占位），但保留其内部
//    的两个 .toggle（功能 DOM）。用 position:absolute 把它们从布局里拎出来。
.header .site-brand-container {
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
  padding: 0;
  position: static;   // 让 .toggle 的 position:fixed 以视口为参考
}

// 3) 隐藏默认 header 的 brand 文本与 logo 装饰（自定义 header 已有 brand）
.header .site-meta,
.header .site-meta .brand,
.header .site-meta .site-title,
.header .site-meta .site-subtitle,
.header .site-meta .logo-line,
.header .site-meta .custom-logo-image {
  display: none !important;
}

// 4) 两个功能按钮：用 position:fixed 浮在视口角落，叠在 .custom-header 之上，
//    保证可点击。z-index 高于 .custom-header(100)。
//    - .site-nav-toggle .toggle（汉堡）：仅移动端可见，桌面端由自定义 header 导航
//    - .site-nav-right  .toggle（搜索）：所有断点都可见，因为移除 menu.njk 后，
//      这是唯一的搜索入口（local-search.js / algolia-search.js 通过 .popup-trigger 绑定）
.header .site-nav-toggle,
.header .site-nav-right {
  display: block;   // 覆盖 NexT 默认 display:none（site-nav.styl）
}

// 桌面端（>= 768px）：隐藏汉堡（自定义 header 提供导航），保留搜索按钮
@media (min-width: 768px) {
  .header .site-nav-toggle {
    display: none !important;
  }
  // 搜索按钮浮在自定义 header 右侧
  .header .site-nav-right .toggle {
    position: fixed;
    top: 22px;       // 与 .custom-header-inner 桌面端 padding(24px) 对齐
    right: 24px;
    z-index: 110;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--text-color, #09090b);
    padding: 8px;
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
}

// 移动端（<= 767px）：汉堡 + 搜索都 fixed 到视口角落
@media (max-width: 767px) {
  .header .site-nav-toggle .toggle,
  .header .site-nav-right .toggle {
    position: fixed;
    top: 18px;        // 与 .custom-header-inner 移动端 padding(16px) 大致对齐
    z-index: 110;     // 高于 .custom-header(100)
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--text-color, #09090b);
    padding: 8px;
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .header .site-nav-toggle .toggle {
    left: 20px;
  }
  .header .site-nav-right .toggle {
    right: 20px;
  }
  // 汉堡线条颜色随文本色
  .header .site-nav-toggle .toggle .toggle-line {
    background: var(--text-color, #09090b);
  }
  // 搜索弹层在移动端满屏（NexT 原生已有，这里仅确保 z-index 高于 header）
  .search-pop-overlay {
    z-index: 200;
  }
}

// 暗色模式下功能按钮颜色对齐自定义 header 暗色文本
// 用 [data-theme] 替代 prefers-color-scheme
[data-theme="dark"] .header .site-nav-toggle .toggle,
[data-theme="dark"] .header .site-nav-right .toggle {
  color: #f4f4f5;
}
[data-theme="dark"] .header .site-nav-toggle .toggle .toggle-line {
  background: #f4f4f5;
}

// 5) 防御性兜底：NexT motion 开启时会把 .site-brand-container .toggle 设为
//    opacity:0 等 GSAP 动画填充。如果 GSAP 加载失败/被 reduce-motion 关闭，
//    搜索按钮会永远不可见不可点。这里强制可见，保证功能不依赖 JS。
.use-motion .header .site-brand-container .toggle {
  opacity: 1 !important;
}
@media (prefers-reduced-motion: reduce) {
  .header .site-nav-toggle .toggle,
  .header .site-nav-right .toggle {
    opacity: 1 !important;
  }
}
